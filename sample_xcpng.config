[Config]

[Servers]
# Format: IP_ADDRESS	HOSTNAME	PASSWORD (tab-separated)
# Example entries:
192.168.1.10	xcpng01	your_password_here
192.168.1.11	xcpng02	your_password_here
192.168.1.12	xcpng03	your_password_here

# Copy this file to xcpng.config and update with your server details:
#   cp sample_xcpng.config xcpng.config
#   chmod 600 xcpng.config
